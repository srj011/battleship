##################################################
# Root
##################################################

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# OS files
.DS_Store
Thumbs.db

##################################################
# Rust Backend
##################################################

# Cargo build output
/backend/target/

# Keep Cargo.lock (app, not lib)
# /backend/Cargo.lock

# Rust incremental compilation
**/*.rs.bk

##################################################
# Frontend (SvelteKit + Bun)
##################################################

# Dependencies
/frontend/node_modules/

# SvelteKit build output
/frontend/.svelte-kit/

# Production build output (adapter dependent)
/frontend/build/
/frontend/dist/

# Vite cache (still used internally)
/frontend/.vite/

# Environment files (optional, if frontend uses them)
/frontend/.env
/frontend/.env.*

# TypeScript
/frontend/*.tsbuildinfo

# Testing
/frontend/coverage/

##################################################
# IDE / Editor
##################################################

# Zed
.zed/

# VSCode
.vscode/

# JetBrains
.idea/

# Vim
*.swp
*.swo

##################################################
# Testing (global)
##################################################

coverage/
*.lcov

##################################################
# Temporary files
##################################################

*.tmp
*.temp
*.pid
*.seed
