##################################################
# Root
##################################################

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# OS files
.DS_Store
Thumbs.db

##################################################
# Rust Backend
##################################################

# Cargo build output
/backend/target/

# Keep Cargo.lock (app, not lib)
# /backend/Cargo.lock

# Rust incremental compilation
**/*.rs.bk

##################################################
# Frontend (SvelteKit + Bun)
##################################################

# Handled by frontend/.gitignore

##################################################
